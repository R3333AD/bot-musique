server:
  port: 2333
  address: 0.0.0.0

lavalink:
  server:
    password: "${LAVALINK_PASSWORD}"
    bufferDurationMs: 400
    sources:
      youtube: false
      soundcloud: true
      bandcamp: false
      twitch: false
      http: false
      local: false
  plugins:
    - dependency: "dev.lavalink.youtube:youtube-plugin:1.18.1"
      repository: "https://maven.lavalink.dev/releases"
    - dependency: "com.github.topi314.lavasrc:lavasrc-plugin:4.8.3"
      repository: "https://maven.lavalink.dev/releases"

plugins:
  youtube:
    enabled: true
    clients:
      # Ordre par fiabilité décroissante
      - MUSIC
      - ANDROID_MUSIC
      - TV
      - ANDROID_VR
      - WEB
      - WEB_EMBEDDED_PLAYER
  lavasrc:
    providers:
      # ISRC d'abord (matching quasi exact), puis recherche texte sur YouTube Music
      # (meilleure qualité que ytsearch classique : versions studio prioritaires)
      - "ytmsearch:\"%ISRC%\""
      - "ytmsearch:%QUERY%"
    # --- Spotify : nécessite un compte Spotify Premium depuis fév. 2026 ---
    # Laisse vide et sources.spotify=false si tu n'as pas de compte Premium.
    # Le bot utilise alors un fallback par scraping (déjà en place dans music.py),
    # plus fragile mais qui ne demande aucun compte.
    # Si tu as Premium : renseigne SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET dans
    # .env et passe sources.spotify à true ci-dessous.
    spotify:
      clientId: "${SPOTIFY_CLIENT_ID}"
      clientSecret: "${SPOTIFY_CLIENT_SECRET}"
      countryCode: "FR"
    sources:
      spotify: false
    soundcloud:
      enabled: true
